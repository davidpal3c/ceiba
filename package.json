{
  "name": "@ceibalabs/ceiba-sdk",
  "version": "0.0.1",
  "description": "Node SDK for adding API keys, quotas, and subscription-gated access to Express and Fastify APIs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prove": "tsx scripts/prove-authorize.ts"
  },
  "dependencies": {
    "@ceibalabs/ceiba-core-domain": "file:../ceiba-core-domain",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "express": "^4.21.2",
    "fastify": "^5.2.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "express": "^4.21.0 || ^5.0.0",
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true }
  },
  "license": "MIT",
  "keywords": ["ceiba", "api", "express", "fastify", "middleware"],
  "author": "David Palacios"
}
